# ==========================================================================
# Radiance — Bible Worlds 3DGS Asset PoC · .gitignore
# ==========================================================================

# --- Secrets / local environment (NEVER commit) ---
.env
.env.*
.env.runpod.local
*.key
*.pem

# --- Scratch / working notes ---
tmp/

# ==========================================================================
# Project artifacts (large; live on the Pod Network Volume, not in git)
#   per radiance.org §1.0: data/ outputs/ envs/ are volume-resident
# ==========================================================================
data/
outputs/
envs/
checkpoints/
# external repos (Relightable3DGaussian, gaussian-grouping, nvdiffrast) —
# cloned on the Pod AND locally for reference; non-commercial license, never committed
third_party/

# --- 3DGS / training outputs ---
*.ply
*.pth
*.ckpt
*.splat
*.usdz
*.npz
*.hdr
*.exr
*.log
sparse/
colmap/
*.mp4
*.mov
*.glb
*.gltf

# ==========================================================================
# Python
# ==========================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.conda/

# --- Testing / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache
nosetests.xml
coverage.xml
*.cover

# --- Type checkers / linters ---
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.ruff_cache/

# ==========================================================================
# Jupyter / IPython (org-babel workflow runs on the remote kernel)
# ==========================================================================
.ipynb_checkpoints/
profile_default/
ipython_config.py
*.ipynb
# org-babel (emacs-jupyter) inline image outputs
.ob-jupyter/
_contact.png

# ==========================================================================
# Emacs / org-mode
# ==========================================================================
*~
\#*\#
.\#*
.org-id-locations
*_archive
/auto/
.dir-locals.el

# ==========================================================================
# OS / editor cruft
# ==========================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
.idea/
.vscode/

# ==========================================================================
# OMC orchestration state (local only)
# ==========================================================================
.omc/
